# LLM (optional — without key, rule-based classifier is used)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Telegram (channel 1)
TELEGRAM_BOT_TOKEN=

# App
HOST=0.0.0.0
PORT=8000
DATABASE_PATH=data/tickets.db
KNOWLEDGE_DIR=knowledge/faq

# Business hours for after-hours scenario (local timezone)
BUSINESS_TZ=Europe/Kyiv
BUSINESS_START_HOUR=9
BUSINESS_END_HOUR=18

# Mock billing wallet for scenario C-2
BILLING_WALLET_ADDRESS=0xGATUM_DEMO_WALLET_ADDRESS

# Optional: notify support lead on negative sentiment (C-8 bonus)
SUPPORT_LEAD_WEBHOOK_URL=

# Set false during demo to test all scenarios in daytime
AFTER_HOURS_CHECK_ENABLED=true
